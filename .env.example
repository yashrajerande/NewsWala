# NewsWala — Environment Variables
# Copy this file to .env and fill in your values
# (Never commit .env to git — it contains secrets)

# Required: Anthropic API key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for Telegram delivery
# Step 1: Open Telegram → search @BotFather → /newbot → follow prompts → copy token
TELEGRAM_BOT_TOKEN=7123456789:AAHdqTcvCH1vGBJ_your_token_here

# Step 2: Start a chat with your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Find "chat":{"id": XXXXXXX} → paste that number below
TELEGRAM_CHAT_ID=123456789
